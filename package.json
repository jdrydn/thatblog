{
  "name": "@thatblog/repo",
  "version": "0.1.0",
  "description": "Serverless blog platform",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "pnpm run --recursive --if-present --workspace-concurrency 1 build",
    "lint": "pnpm run --recursive --if-present --workspace-concurrency 1 lint",
    "test:unit": "pnpm run --recursive --if-present --no-bail --workspace-concurrency 1 test:unit"
  },
  "author": "jdrydn <james@jdrydn.com> (https://jdrydn.com)",
  "license": "MIT",
  "repository": "https://github.com/jdrydn/thatblog",
  "bugs": "https://github.com/jdrydn/thatblog/issues",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/lib-dynamodb": "^3.1030.0",
    "@middy/core": "^7.2.2",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
